# ─────────────────────────────────────────────────────────────────────────────
# Legal Agent Forge — окружение
# ─────────────────────────────────────────────────────────────────────────────

# --- Выбор движка ------------------------------------------------------------
# Принудительно включить детерминированный офлайн-движок (без вызовов LLM). Также через `--offline`.
# FORGE_OFFLINE=1

# Где живут рабочие папки агентов (по умолчанию: ./.forge). Также через `--home`.
# FORGE_HOME=./.forge

# --- Переиспользуемые сервисы (только если не установлены / не соседи этого репозитория) ---
# DEVASSIST_PATH=/abs/path/to/devassist        # предоставляет devassist.llm (GigaChat)
# EXTRACTORS_PATH=/abs/path/to/test            # репозиторий с пакетом `extractors`
# FORGE_PATH=/abs/path/to/legal_agent_forge    # используется в agent.py упакованного агента

# --- Учётные данные GigaChat (потребляются переиспользуемым провайдером devassist) ---
# Внешний контур (OAuth): задайте Basic-ключ доступа.
# GIGACHAT_ACCESS_KEY=your_base64_access_key
# GIGACHAT_SCOPE=GIGACHAT_API_PERS
# GIGACHAT_MODEL=GigaChat-3-Ultra

# Внутренний контур (mTLS): задайте клиентский сертификат + ключ вместо ключа доступа.
# GIGACHAT_CERT=/abs/path/to/client.pem
# GIGACHAT_KEY=/abs/path/to/client.key
# GIGACHAT_VERIFY_SSL=false
